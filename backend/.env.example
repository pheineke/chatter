# Copy to .env and fill in your values
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chat

# ⚠  IMPORTANT: Change this to a strong, unique value!
#    A warning is printed at startup if the default is still in use.
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list of user IDs allowed to generate decoration codes.
# Set to "*" (default) to allow any authenticated user (dev mode).
# In production, restrict to specific admin user UUIDs.
# DECORATION_ADMIN_IDS=*
